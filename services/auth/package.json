{
  "name": "hive-auth",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "postinstall": "prisma generate",
    "pretest": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@hive/auth": "workspace:*",
    "@prisma/client": "^6.8.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prisma": "^6.8.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
