    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hive/auth": "workspace:*",
    "@hive/db": "workspace:*",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
