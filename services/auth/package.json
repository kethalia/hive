{
  "name": "hive-auth",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "test": "vitest run",
