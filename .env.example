DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379
# 32-byte hex key for encrypting/decrypting per-user Coder API tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Terminal proxy WebSocket URL (required for terminal sessions)
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:3001

# Comma-separated list of allowed origins for WebSocket connections (CSRF protection)
# Supports wildcards for ports (e.g. http://localhost:*)
# Defaults to http://localhost:* and https://localhost:* if not set
ALLOWED_ORIGINS=

# Auth service URL for session management and login delegation
AUTH_SERVICE_URL=http://localhost:4400

# HMAC-SHA256 secret for signing/verifying session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Optional cookie Domain attribute. Set to a shared parent so the session
# cookie is sent to sibling subdomains (e.g. the terminal-proxy host).
# Use a leading dot for broadest match: ".local.kethalia.com", ".kethalia.com".
# Leave unset for localhost / single-host deployments.
COOKIE_DOMAIN=

# Coder deployment URL (fallback used by terminal-proxy when the auth service
# response does not include a coderUrl). Required for local/dev terminals.
# CODER_URL is checked first, then CODER_AGENT_URL.
CODER_URL=http://localhost:7080
CODER_AGENT_URL=

# Comma-separated allowlist of Coder deployment URLs accepted at login.
# Acts as the security boundary for which Coder instances users may sign in to.
ALLOWED_CODER_URLS=http://localhost:7080

# Coder workspace template IDs used when dispatching tasks.
# Get IDs from `coder templates list` against the target deployment.
CODER_WORKER_TEMPLATE_ID=
CODER_VERIFIER_TEMPLATE_ID=
CODER_COUNCIL_TEMPLATE_ID=

# Default AI provider/model passed to worker tasks (pi CLI flags).
PI_PROVIDER=anthropic
PI_MODEL=claude-opus-4-7

# Number of concurrent task-queue workers (default: 5)
WORKER_CONCURRENCY=5

# Grace period in ms before reaping stale workspaces (default: 60000)
CLEANUP_GRACE_MS=60000

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Auth service bind port (default: 4400)
AUTH_SERVICE_PORT=4400

# Terminal proxy bind host (default: 0.0.0.0)
BIND_HOST=0.0.0.0
