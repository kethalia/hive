DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379
CODER_AGENT_URL=

# 32-byte hex key for encrypting/decrypting per-user Coder API tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Terminal proxy WebSocket URL (required for terminal sessions)
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:3001

# Comma-separated list of allowed origins for WebSocket connections (CSRF protection)
# Supports wildcards for ports (e.g. http://localhost:*)
# Defaults to http://localhost:* and https://localhost:* if not set
ALLOWED_ORIGINS=

# Auth service URL for session management and login delegation
AUTH_SERVICE_URL=http://localhost:4400

# HMAC-SHA256 secret for signing/verifying session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=
