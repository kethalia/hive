{
  "name": "hive-orchestrator",
  "version": "2.1.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:services": "docker compose -f docker-compose.dev.yml up",
    "dev:services:start": "docker compose -f docker-compose.dev.yml up -d",
    "dev:services:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:auth": "pnpm --filter hive-auth dev",
    "dev:terminal-proxy": "pnpm --filter hive-terminal-proxy dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "pnpm -r test",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "postinstall": "npx prisma generate",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "ci:release": "changeset tag"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hive/auth": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ioredis": "^5.4.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-safe-action": "^8.1.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tar-stream": "^3.1.8",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/tar-stream": "^3.1.4",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
