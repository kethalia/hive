{
  "name": "hive-web",
  "version": "2.5.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:services": "docker compose -f docker-compose.dev.yml up",
    "dev:services:start": "docker compose -f docker-compose.dev.yml up -d",
    "dev:services:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:auth": "pnpm --filter hive-auth dev",
    "dev:terminal-proxy": "pnpm --filter hive-terminal dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm -r test",
    "db:studio": "pnpm --filter @hive/db db:studio",
    "db:push": "pnpm --filter @hive/db db:push",
    "db:generate": "pnpm --filter @hive/db db:generate",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "ci:release": "changeset tag"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hive/auth": "workspace:*",
    "@hive/db": "workspace:*",
    "@tanstack/react-virtual": "^3.13.23",
    "@use-gesture/react": "^10.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "ioredis": "^5.4.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-safe-action": "^8.1.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.10.0",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tar-stream": "^3.1.8",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@hive/db",
      "@prisma/client",
      "prisma",
      "@prisma/engines"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.30.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/tar-stream": "^3.1.4",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
