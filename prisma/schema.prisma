generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  queued
  running
  verifying
  done
  failed
}

enum WorkspaceStatus {
  pending
  starting
  running
  stopped
  deleted
  failed
}

model Task {
  id           String     @id @default(uuid()) @db.Uuid
  prompt       String
  repoUrl      String     @map("repo_url")
  status       TaskStatus @default(queued)
  branch       String?
  prUrl        String?    @map("pr_url")
  errorMessage       String?    @map("error_message")
  verificationReport Json?      @map("verification_report")
  councilSize        Int        @default(3) @map("council_size")
  councilReport      Json?      @map("council_report")
  attachments        Json?
  userId             String?    @map("user_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user       User?       @relation(fields: [userId], references: [id])
  logs       TaskLog[]
  workspaces Workspace[]

  @@map("tasks")
}

model TaskLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  message   String
  level     String   @default("info")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_logs")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  coderUrl    String   @map("coder_url")
  coderUserId String   @map("coder_user_id") @db.Uuid
  username    String
  email       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  coderTokens CoderToken[]
  sessions    Session[]
  tasks       Task[]

  @@unique([coderUrl, coderUserId])
  @@map("users")
}

model CoderToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes    @map("auth_tag")
  version    Int       @default(1)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("coder_tokens")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @unique @default(uuid()) @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Workspace {
  id               String          @id @default(uuid()) @db.Uuid
  taskId           String          @map("task_id") @db.Uuid
  coderWorkspaceId String?         @map("coder_workspace_id")
  templateType     String          @default("worker") @map("template_type")
  status           WorkspaceStatus @default(pending)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id])

  @@map("workspaces")
}
