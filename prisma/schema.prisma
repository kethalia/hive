generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  queued
  running
  verifying
  done
  failed
}

enum WorkspaceStatus {
  pending
  starting
  running
  stopped
  deleted
  failed
}

model Task {
  id           String     @id @default(uuid()) @db.Uuid
  prompt       String
  repoUrl      String     @map("repo_url")
  status       TaskStatus @default(queued)
  branch       String?
  prUrl        String?    @map("pr_url")
  errorMessage       String?    @map("error_message")
  verificationReport Json?      @map("verification_report")
  attachments        Json?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  logs       TaskLog[]
  workspaces Workspace[]

  @@map("tasks")
}

model TaskLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  message   String
  level     String   @default("info")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id])

  @@map("task_logs")
}

model Workspace {
  id               String          @id @default(uuid()) @db.Uuid
  taskId           String          @map("task_id") @db.Uuid
  coderWorkspaceId String?         @map("coder_workspace_id")
  templateType     String          @default("worker") @map("template_type")
  status           WorkspaceStatus @default(pending)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id])

  @@map("workspaces")
}
