#!/bin/sh
# KasmVNC xstartup — starts the desktop environment after the display is ready.
# Baked into the Docker image at /etc/kasmvnc/xstartup.
# With desktop_environment = "xfce", KasmVNC starts XFCE natively — this file
# is only used as a fallback when select-de is "manual".

unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
[ -r "$HOME/.Xresources" ] && xrdb "$HOME/.Xresources"

if command -v startxfce4 >/dev/null 2>&1; then
  exec startxfce4
else
  echo "ERROR: XFCE not found (startxfce4 missing)" >&2
  sleep infinity
fi
